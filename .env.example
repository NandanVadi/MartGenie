# MartGenie Environment Variables Template
# Copy this to .env (for local) or set in Render Dashboard (for production)

# Django Core Settings
SECRET_KEY=your-super-secret-key-here
DEBUG=False
ALLOWED_HOSTS=martgenie.com,www.martgenie.com,martgenie.onrender.com

# Database Configuration (Supabase/PostgreSQL)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=your-database-url-here

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Render Specific (Added automatically by Render, but good to know)
# RENDER_EXTERNAL_HOSTNAME=martgenie.onrender.com
